# Workspace environment
# 1. Copy this file:  cp .env.example .env
# 2. Run setup:       make init    (auto-detects your Laravel app)
#
# To change the active app: make reconfigure

# --- App (set automatically by `make setup`) ---
APP_NAME=
APP_PATH=

# --- Docker project (set automatically by `make setup`) ---
COMPOSE_PROJECT_NAME=

APP_ENV=local
SERVER_NAME=localhost

# --- Ports ---
APP_HTTP_PORT=8080
APP_HTTPS_PORT=8443

# --- MariaDB (DB_DATABASE and DB_USERNAME set by `make setup`) ---
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root

# --- phpMyAdmin ---
PMA_PORT=8081

# --- Mailpit ---
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# --- Redis ---
REDIS_PORT=6379
